	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@portabletext/types": "^4.0.2",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.6.0",
		"@vitest/browser-playwright": "^4.1.3",
		"mdsvex": "^0.12.7",
		"playwright": "^1.59.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
